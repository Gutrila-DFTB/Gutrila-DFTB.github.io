---
import ExperienceItem from "./ExperienceItem.astro";
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";

const EXPERIENCE = [
  {
    date: "Jun 2023 - Present",
    title: "Quality Data Analyst & Business Intelligence",
    company: "Teleperformance",
    description: 
      "Led a team of 4–6 analysts, built KPI dashboards in Power BI, and designed data quality processes that reduced reporting errors by 15%. 
      Monitored 250+ monthly interactions tracking CSAT, FCR, and AHT metrics, delivering cross-functional reports and actionable coaching to operations and leadership. 
      Developed automated data pipelines using Python and SQL to streamline ETL processes, improving data consistency and reducing manual reporting time. 
      Integrated API testing workflows with Postman and Jira to align QA processes with data validation needs across teams.",
  },
  {
    date: "Mar 2023 - Jun 2023",
    title: "Bilingual Customer Service Agent (B2+)",
    company: "Teleperformance",
    description:
      "Handled English/Spanish support across Voice, Chat, and Email channels, maintaining a customer satisfaction rate above 87%.",
  },
  {
    date: "Dec 2022 - Mar 2023",
    title: "Transfer Process Support",
    company: "Teleperformance",
    description:
      "Supported internal operational transitions, adapting processes and documentation during organizational restructuring.",
  },
  {
    date: "Aug 2021 - Dec 2022",
    title: "Customer Service Representative",
    company: "Teleperformance",
    description:
      "Consistently ranked in the top 10% for resolution efficiency and customer satisfaction across assigned targets.",
  },
  {
    date: "2020 - 2022",
    title: "Administrative Assistant (Internship)",
    company: "Local School - Nueva Generación Altamira",
    description:
      "Embraced document management, phone service, and scheduling coordination.",
  },
];
---

<section class="py-8 px-8 max-md:py-4 mb-4 scroll-m-16" id="experience">
  <div class="flex flex-col pt-8 max-w-4xl mx-auto">
    <div class="flex gap-4 items-center justify-center">
      <Icon class="text-3xl dark:text-white text-blacktext" name="briefcase" />
      <Heading text="Work" textGradient="Experience" level={2} />
    </div>

    <div class="relative max-md:mt-0 mt-8" aria-label="Professional experience">
      <ol class="relative mt-10">
        {
          EXPERIENCE.map((experience, index) => (
            <li>
              <article
                role="article"
                aria-labelledby={`experience-title-${index}`}
              >
                <div
                  class="flex flex-col gap-2  text-zinc-00 dark:text-zinc-300 md:col-span-3"
                  aria-describedby={`experience-title-${index}`}
                >
                  <ExperienceItem {...experience} />
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
